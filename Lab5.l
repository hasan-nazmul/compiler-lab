%{
// Include the header generated by YACC
#include "y.tab.h"
%}

%%
[0-9]+ { 
    return NUMBER; 
}

[a-zA-Z_][a-zA-Z0-9_]* { 
    return ID; 
}

[ \t]+ { 
    /* Ignore whitespace */ 
}

\n { 
    return '\n'; 
}

. { 
    // Return operators (+, -, *, /, etc.) and parentheses as their literal ASCII values
    return yytext[0]; 
}
%%

int yywrap() {
    return 1;
}